{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rvbernucci/track1-token-router/schemas/feature-vector-v1.schema.json",
  "title": "FeatureVector v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "names", "values"],
  "properties": {
    "schema_version": {"const": "feature-vector-v1"},
    "names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "number", "minimum": 0, "maximum": 1}
    }
  }
}
