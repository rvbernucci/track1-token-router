# Source runbook: docs/RUNBOOK_FIREWORKS.md
# Serverless Fireworks auditor profile. Keep API key outside git.

ROUTER_MODE=fireworks
ROUTER_POLICY=balanced
ROUTER_LOG_PATH=logs/fireworks-serverless-run.jsonl

FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Official ACT II harness injects ALLOWED_MODELS. FIREWORKS_MODEL is a local override.
ALLOWED_MODELS=
FIREWORKS_MODEL=
FIREWORKS_CHAMPION_MODEL=accounts/fireworks/models/kimi-k2p7-code
FIREWORKS_API_KEY=
FIREWORKS_TIMEOUT_S=24
FIREWORKS_MAX_RETRIES=0
FIREWORKS_TEMPERATURE=0.0
FIREWORKS_MAX_TOKENS=256
FIREWORKS_SERVICE_TIER=
FIREWORKS_MATRIX_WEIGHTS=router/data/fireworks_track1_allowed_weights.json
FIREWORKS_INTENT_POLICY=configs/fireworks-intent-policy-v2.json
FIREWORKS_INTENT_POLICY_SHA256=87a9d2a96453f06e49ea574f5fe0d11b4f41214560efa8281e09adb66856a124

MAX_REMOTE_TOKENS_PER_TASK=300
MAX_REMOTE_TOKENS_PER_RUN=6000
MAX_REMOTE_LATENCY_MS=3000
