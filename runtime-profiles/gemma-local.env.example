# Source runbook: docs/RUNBOOK_GEMMA.md
# Local OpenAI-compatible Gemma endpoint profile.

ROUTER_MODE=competition
COMPETITION_DRY_RUN=0
ROUTER_POLICY=balanced
ROUTER_LOG_PATH=logs/gemma-local-run.jsonl

LOCAL_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_MODEL=google/gemma-4-31b-it
LOCAL_API_KEY=
LOCAL_TIMEOUT_S=60
LOCAL_MAX_RETRIES=0

M1_TEMPERATURE=0.2
M1_MAX_TOKENS=512
M2A_TEMPERATURE=0.0
M2A_MAX_TOKENS=256
M2B_TEMPERATURE=0.2
M2B_MAX_TOKENS=768

MAX_REMOTE_TOKENS_PER_TASK=300
MAX_REMOTE_TOKENS_PER_RUN=6000
MAX_REMOTE_LATENCY_MS=3000

GEMMA_MODEL_FAMILY=Gemma
GEMMA_MODEL_SIZE=31B
GEMMA_QUANTIZATION=none
GEMMA_PROMPT_FORMAT=gemma4
