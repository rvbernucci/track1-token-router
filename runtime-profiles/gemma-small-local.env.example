# Source runbook: docs/RUNBOOK_GEMMA.md
# Small local Gemma challenger profile for the final 4 GB RAM / 2 vCPU envelope.

ROUTER_MODE=hybrid
COMPETITION_DRY_RUN=0
ROUTER_POLICY=conservative
ROUTER_LOG_PATH=logs/gemma-small-local-run.jsonl

LOCAL_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_MODEL=local-gemma-small
LOCAL_API_KEY=
LOCAL_TIMEOUT_S=12
LOCAL_MAX_RETRIES=0
LOCAL_CONTEXT_TOKENS=2048
LOCAL_MEMORY_BUDGET_MB=3400

M1_TEMPERATURE=0.0
M1_MAX_TOKENS=128
M2A_TEMPERATURE=0.0
M2A_MAX_TOKENS=96
M2B_TEMPERATURE=0.0
M2B_MAX_TOKENS=128

FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=minimax-m3,kimi-k2p7-code,gemma-4-31b-it,gemma-4-26b-a4b-it,gemma-4-31b-it-nvfp4
FIREWORKS_MODEL=
FIREWORKS_API_KEY=
FIREWORKS_TIMEOUT_S=24
FIREWORKS_MAX_RETRIES=0
FIREWORKS_TEMPERATURE=0.0
FIREWORKS_MAX_TOKENS=256

MAX_REMOTE_TOKENS_PER_TASK=300
MAX_REMOTE_TOKENS_PER_RUN=6000
MAX_REMOTE_LATENCY_MS=3000

GEMMA_MODEL_FAMILY=Gemma
GEMMA_MODEL_SIZE=E2B
GEMMA_QUANTIZATION=qat-q4_0
GEMMA_PROMPT_FORMAT=gemma4
