# Runtime mode: mock, auto, local, cascade, hybrid
ROUTER_MODE=mock
ROUTER_POLICY=balanced
ROUTER_LOG_PATH=logs/run.jsonl
ENABLE_GUARDRAILS=0

# Local OpenAI-compatible inference endpoint
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_MODEL=local-model
LOCAL_API_KEY=
LOCAL_TIMEOUT_S=30
LOCAL_MAX_RETRIES=1

# Local generation and verification parameters
M1_TEMPERATURE=0.2
M1_MAX_TOKENS=512
M2A_TEMPERATURE=0.0
M2A_MAX_TOKENS=256
M2B_TEMPERATURE=0.2
M2B_MAX_TOKENS=768

# Fireworks OpenAI-compatible endpoint
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/replace-me
FIREWORKS_API_KEY=
FIREWORKS_TIMEOUT_S=60
FIREWORKS_MAX_RETRIES=1
FIREWORKS_TEMPERATURE=0.0
FIREWORKS_MAX_TOKENS=256
