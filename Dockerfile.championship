FROM debian:bookworm-slim AS llama

ARG LLAMA_URL=https://github.com/ggml-org/llama.cpp/releases/download/b9948/llama-b9948-bin-ubuntu-x64.tar.gz
ARG LLAMA_SHA256=9fd15007f9058e2cf6d8d81e0856ffc351f59a70ff3ad08720992835cbb9320a
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/* \
    && test -n "$LLAMA_SHA256" \
    && curl -fL --retry 4 -o /tmp/llama.tar.gz "$LLAMA_URL" \
    && echo "$LLAMA_SHA256  /tmp/llama.tar.gz" | sha256sum -c - \
    && mkdir -p /opt/llama \
    && tar -xzf /tmp/llama.tar.gz -C /opt/llama --strip-components=1 \
    && rm /tmp/llama.tar.gz

FROM debian:bookworm-slim AS models

ARG FUNCTIONGEMMA_URL=https://github.com/rvbernucci/track1-token-router/releases/download/model-assets-v1/functiongemma-scale789-q8_0.gguf
ARG FUNCTIONGEMMA_PLANNER_URL=https://github.com/rvbernucci/track1-token-router/releases/download/model-assets-v1/functiongemma-tool-planner-q8_0.gguf
ARG E2B_URL=https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm/resolve/6664aee5fc114b486e2fec56a9f73c0146e79e74/gemma-4-E2B-it.litertlm?download=true
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /models/functiongemma /models/functiongemma-planner /models/e2b \
    && curl -fL --retry 8 --retry-all-errors -o /models/functiongemma/model.gguf "$FUNCTIONGEMMA_URL" \
    && echo '74625dd27cf25d54018fa17328a1b1b43f1f09c179e1e4edfaeeffc0c05d9b77  /models/functiongemma/model.gguf' | sha256sum -c - \
    && curl -fL --retry 8 --retry-all-errors -o /models/functiongemma-planner/model.gguf "$FUNCTIONGEMMA_PLANNER_URL" \
    && echo 'ec412795782acd3ed836ac35e058099bfdb1c3218a1ee86aef32905377dbddaf  /models/functiongemma-planner/model.gguf' | sha256sum -c - \
    && curl -fL --retry 8 --retry-all-errors -o /models/e2b/model.litertlm "$E2B_URL" \
    && echo '181938105e0eefd105961417e8da75903eacda102c4fce9ce90f50b97139a63c  /models/e2b/model.litertlm' | sha256sum -c -

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    LITERT_LM_DIR=/opt/litert \
    LD_LIBRARY_PATH=/opt/llama \
    ROUTER_LOG_PATH=/tmp/proofroute/run.jsonl \
    ROUTER_MODE=three_route \
    COMPETITION_DRY_RUN=0 \
    FUNCTIONGEMMA_BASE_URL=http://127.0.0.1:8091/v1 \
    FUNCTIONGEMMA_MODEL=functiongemma-q8 \
    FUNCTIONGEMMA_MAX_TOKENS=64 \
    FUNCTIONGEMMA_TIMEOUT_S=5 \
    FUNCTIONGEMMA_CALIBRATION=/app/configs/functiongemma-scale789-q8-calibration.json \
    FUNCTIONGEMMA_CALIBRATION_SHA256=0078565ab90a6c93981e954d13daabdaa11a4535da9257eae03f3a034afcc1e1 \
    FUNCTIONGEMMA_PLANNER_BASE_URL=http://127.0.0.1:8092/v1 \
    FUNCTIONGEMMA_PLANNER_MODEL=functiongemma-planner \
    FUNCTIONGEMMA_PLANNER_MAX_TOKENS=160 \
    FUNCTIONGEMMA_PLANNER_TIMEOUT_S=8 \
    DUAL_FUNCTIONGEMMA_POLICY=/app/configs/dual-functiongemma-policy-v1-promoted.json \
    DUAL_FUNCTIONGEMMA_POLICY_SHA256=611dfac1494674e0a423ddda1ddc06ca01d3671afb2660519b5e97a328d97ff4 \
    E2B_BASE_URL=http://127.0.0.1:9379/v1 \
    E2B_MODEL=gemma4-e2b \
    E2B_MAX_TOKENS=96 \
    E2B_TIMEOUT_S=30 \
    OUTCOME_MODELS_PATH=/app/configs/engine-outcome-models-v1.json \
    OUTCOME_MODELS_SHA256=927a64303501d43f3b509a8f48d397d372c4211f8347890827206e82bda60712 \
    E2B_ROUTE_POLICY=/app/configs/e2b-route-policy-v1.json \
    E2B_ROUTE_POLICY_SHA256=24607dda80f861ecde022987111302590b0e17a61842ad5b3e0b17302047c4ad \
    E2B_MATRIX_POLICY=/app/configs/e2b-category-matrix-regression-v2.json \
    E2B_MATRIX_POLICY_SHA256=4597acd2266c43c7a8ea281915d7e9afe89af40788f42eff300112138631c481 \
    RISK_LADDER_POLICY=/app/configs/wilson-nash-risk-ladder-v1.json \
    RISK_LADDER_POLICY_SHA256=66a85965cd271b22a8a91696e6506f7f99dda4186d54b59b3eb2d6ced42aab53 \
    THREE_ROUTE_MAX_MEMORY_MB=3584 \
    FIREWORKS_MATRIX_WEIGHTS=/app/router/data/fireworks_track1_allowed_weights.json \
    FIREWORKS_INTENT_POLICY=/app/configs/fireworks-intent-policy-v2.json \
    FIREWORKS_INTENT_POLICY_SHA256=87a9d2a96453f06e49ea574f5fe0d11b4f41214560efa8281e09adb66856a124 \
    TRACK1_RUNTIME_RESERVE_S=50 \
    THREE_ROUTE_DEADLINE_RESERVE_MS=50000 \
    FIREWORKS_MAX_TOKENS=512 \
    FIREWORKS_TIMEOUT_S=24 \
    FIREWORKS_MAX_RETRIES=0 \
    ENABLE_GUARDRAILS=1 \
    ENABLE_ORCHESTRATOR=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl libgomp1 libvulkan1 mesa-vulkan-drivers \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir litert-lm==0.14.0

COPY --from=llama /opt/llama /opt/llama
COPY pyproject.toml README.md ./
COPY router ./router
COPY configs ./configs
COPY scripts/litert_cpu_server.py scripts/championship_entrypoint.sh ./scripts/
COPY --from=models /models/functiongemma/model.gguf ./artifacts/functiongemma-scale789/functiongemma-scale789-q8_0.gguf
COPY --from=models /models/functiongemma-planner/model.gguf ./artifacts/functiongemma-tool-planner/functiongemma-tool-planner-q8_0.gguf
COPY --from=models /models/e2b/model.litertlm /opt/litert/models/gemma4-e2b/model.litertlm

RUN pip install --no-cache-dir . \
    && chmod +x /app/scripts/championship_entrypoint.sh \
    && printf '%s  %s\n' \
      '74625dd27cf25d54018fa17328a1b1b43f1f09c179e1e4edfaeeffc0c05d9b77' \
      '/app/artifacts/functiongemma-scale789/functiongemma-scale789-q8_0.gguf' | sha256sum -c - \
    && printf '%s  %s\n' \
      'ec412795782acd3ed836ac35e058099bfdb1c3218a1ee86aef32905377dbddaf' \
      '/app/artifacts/functiongemma-tool-planner/functiongemma-tool-planner-q8_0.gguf' | sha256sum -c - \
    && printf '%s  %s\n' \
      '181938105e0eefd105961417e8da75903eacda102c4fce9ce90f50b97139a63c' \
      '/opt/litert/models/gemma4-e2b/model.litertlm' | sha256sum -c - \
    && mkdir -p /app/logs /app/reports/generated

ENTRYPOINT ["/app/scripts/championship_entrypoint.sh"]
